# =========================
# SYSTEM / TEMP FILES
# =========================
__pycache__/
.ipynb_checkpoints/

# =========================
# LARGE / RAW DATA FILES
# =========================
*.gz
*.tar.gz
*.zip

# =========================
# MODEL FILES / INDEXES
# =========================
*.index
*.pth

# =========================
# DATA (ignore all, allow samples)
# =========================
data/*
!data/mimic_sample/
!data/pmc_sample/

# =========================
# RESULTS (ignore all, allow summaries)
# =========================
results/*
!results/*.csv
!results/*.json
!results/figures/

# =========================
# IMAGES (allow important ones)
# =========================
*.png
!docs/architecture.png
!results/figures/*.png

# =========================
# ENV / INSTALLERS
# =========================
Miniconda3*.sh
